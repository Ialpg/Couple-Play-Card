  <!-- Header card screen -->
  <div class="card-screen-header">
    <button class="card-back-btn" onclick="closeCard()">
      <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
    </button>
    <div class="card-level-badge" id="cardLevelBadge">♥ Level 1</div>
    <button class="card-complete-btn" id="btnComplete" onclick="completeCard()">Hoàn thành ✓</button>
  </div>

  <!-- Card flip area -->
  <div class="card-flip-container" id="cardFlipContainer">
    <div class="card-flip-inner" id="cardFlipInner">

      <!-- Mặt trước: Nội dung -->
      <div class="card-face card-front">
        <div class="card-face-content">
          <div class="card-suit-large" id="cardSuitLarge">♥</div>
          <h2 class="card-title-large" id="cardTitleLarge">Tên lá bài</h2>
          <div class="card-divider">— ✦ —</div>
          <p class="card-description" id="cardDescription">Mô tả chi tiết của lá bài sẽ hiển thị ở đây...</p>

          <!-- Timer -->
          <div class="card-timer" id="cardTimer">
            <div class="timer-display" id="timerDisplay">02:00</div>
            <div class="timer-presets">
              <button onclick="setTimer(60)">1p</button>
              <button onclick="setTimer(90)">1:30</button>
              <button onclick="setTimer(120)">2p</button>
              <button onclick="setTimer(180)">3p</button>
              <button onclick="setTimer(240)">4p</button>
              <button onclick="setTimer(300)">5p</button>
            </div>
            <div class="timer-controls">
              <button class="timer-btn" id="timerStartBtn" onclick="toggleTimer()">▶ Bắt đầu</button>
              <button class="timer-btn timer-reset" onclick="resetTimer()">↺</button>
              <input type="number" id="timerCustom" class="timer-custom" placeholder="giây" min="10" max="3600"
                onchange="setTimer(parseInt(this.value))" />
            </div>
          </div>
        </div>
        <button class="flip-hint" onclick="flipCard()">
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="17 1 21 5 17 9"/><path d="M3 11V9a4 4 0 0 1 4-4h14"/><polyline points="7 23 3 19 7 15"/><path d="M21 13v2a4 4 0 0 1-4 4H3"/></svg>
          Lật xem hình
        </button>
      </div>

      <!-- Mặt sau: Hình ảnh -->
      <div class="card-face card-back-face">
        <div class="card-image-area" id="cardImageArea">
          <div class="image-placeholder" id="imagePlaceholder">
            <div class="placeholder-icon">🌹</div>
            <p>Chưa có hình ảnh</p>
            <label class="btn-upload-image" for="imageUploadInput">
              <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
              Upload hình ảnh
            </label>
            <input type="file" id="imageUploadInput" accept="image/*" class="hidden" onchange="handleImageUpload(event)" />
          </div>
          <img id="cardImage" class="card-image hidden" src="" alt="Hình minh họa" />
          <div class="image-actions hidden" id="imageActions">
            <label class="btn-change-image" for="imageUploadInput2">Đổi hình</label>
            <input type="file" id="imageUploadInput2" accept="image/*" class="hidden" onchange="handleImageUpload(event)" />
            <button class="btn-remove-image" onclick="removeCardImage()">Xóa hình</button>
          </div>
        </div>
        <button class="flip-hint" onclick="flipCard()">
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="17 1 21 5 17 9"/><path d="M3 11V9a4 4 0 0 1 4-4h14"/><polyline points="7 23 3 19 7 15"/><path d="M21 13v2a4 4 0 0 1-4 4H3"/></svg>
          Xem nội dung
        </button>
      </div>
    </div>
  </div>

  <!-- Bottom actions -->
  <div class="card-actions">
    <button class="btn-card-next" onclick="drawCard()">
      Rút tiếp theo
      <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    </button>
  </div>
</div>
