```
<!-- Header -->
<header class="app-header">
  <button class="header-back" onclick="goToLanding()">
    <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
  </button>
  <h2 class="header-title">Couple <em>Play</em></h2>
  <button class="header-action" onclick="openHistory()">
    <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
  </button>
</header>

<!-- Level tabs -->
<div class="level-tabs">
  <button class="level-tab active" data-level="1" onclick="switchLevel(1)">
    <span class="tab-suit">♥</span>
    <span class="tab-name">Dạo đầu</span>
    <span class="tab-count" id="count1">0</span>
  </button>
  <button class="level-tab" data-level="2" onclick="switchLevel(2)">
    <span class="tab-suit">♦</span>
    <span class="tab-name">Trung bình</span>
    <span class="tab-count" id="count2">0</span>
  </button>
  <button class="level-tab" data-level="3" onclick="switchLevel(3)">
    <span class="tab-suit">♣</span>
    <span class="tab-name">Cao</span>
    <span class="tab-count" id="count3">0</span>
  </button>
  <button class="level-tab" data-level="4" onclick="switchLevel(4)">
    <span class="tab-suit">♠</span>
    <span class="tab-name">Rất cao</span>
    <span class="tab-count" id="count4">0</span>
  </button>
</div>

<!-- Nội dung mức độ -->
<div class="level-content">
  <div class="level-panel" id="levelInfo">
    <div class="level-hero" id="levelHero">
      <div class="level-icon" id="levelIcon">♥</div>
      <h3 class="level-title" id="levelTitle">Level 1 — Dạo đầu</h3>
      <p class="level-desc" id="levelDesc">Những hoạt động nhẹ nhàng, lãng mạn để bắt đầu buổi tối</p>
      <div class="level-stats" id="levelStats">
        <span><strong id="totalCards">13</strong> lá bài</span>
        <span>·</span>
        <span><strong id="drawnCards">0</strong> đã rút</span>
        <span>·</span>
        <span><strong id="remainCards">13</strong> còn lại</span>
      </div>
    </div>

    <!-- Nút chơi chính -->
    <div class="play-actions">
      <button class="btn-draw" onclick="drawCard()">
        <span class="draw-icon">✦</span>
        Rút bài ngẫu nhiên
      </button>
      <button class="btn-level-up" onclick="levelUp()">
        <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><polyline points="18 15 12 9 6 15"/></svg>
        Tăng mức độ
      </button>
    </div>

    <!-- Danh sách bài xem trước -->
    <div class="cards-preview">
      <h4 class="preview-title">Danh sách lá bài</h4>
      <div class="cards-grid" id="cardsGrid"></div>
    </div>
  </div>
</div>

<!-- Music Player -->
<div class="music-player" id="musicPlayer">
  <div class="music-header" onclick="toggleMusicExpand()">
    <div class="music-icon">♪</div>
    <div class="music-info">
      <span id="musicTitle">Nhạc nền</span>
    </div>
    <button class="music-toggle-btn">
      <svg id="musicChevron" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="18 15 12 9 6 15"/></svg>
    </button>
  </div>
  <div class="music-body" id="musicBody">
    <!-- Upload nhạc local -->
    <div class="music-upload">
      <label class="btn-music-upload" for="musicFileInput">
        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
        Tải nhạc
      </label>
      <input type="file" id="musicFileInput" accept="audio/*" class="hidden" onchange="loadMusicFile(event)" />
      <input type="text" id="musicUrlInput" class="music-url-input" placeholder="URL nhạc / YouTube..." />
      <button class="btn-music-url" onclick="loadMusicUrl()">Load</button>
    </div>
    <!-- Controls -->
    <div class="music-controls">
      <button class="music-btn" onclick="prevTrack()" title="Trước">⏮</button>
      <button class="music-btn music-play" id="musicPlayBtn" onclick="toggleMusic()">▶</button>
      <button class="music-btn" onclick="nextTrack()" title="Tiếp">⏭</button>
      <input type="range" id="volumeSlider" class="volume-slider" min="0" max="1" step="0.05" value="0.7" oninput="setVolume(this.value)" />
      <span class="volume-icon">🔊</span>
    </div>
    <!-- Playlist -->
    <div class="playlist" id="playlist"></div>
  </div>
</div>

<!-- Reset session -->
<div class="session-bar">
  <button class="btn-reset" onclick="confirmReset()">
    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-4.95L1 10"/></svg>
    Reset phiên chơi
  </button>
</div>
